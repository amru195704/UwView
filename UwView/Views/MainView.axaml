<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:UwView.ViewModels"
             xmlns:ctrl="using:UwView.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="560"
             x:Class="UwView.Views.MainView"
             x:DataType="vm:MainViewModel"
             DragDrop.AllowDrop="True">
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <DockPanel LastChildFill="True">

        <!-- タブストリップ（§4.7） -->
        <Border DockPanel.Dock="Top" Background="#E4E4E4" BorderBrush="#CCCCCC"
                BorderThickness="0,0,0,1" IsVisible="{Binding HasTabs}">
            <TabStrip ItemsSource="{Binding Tabs}"
                      SelectedItem="{Binding ActiveTab, Mode=TwoWay}">
                <TabStrip.ItemTemplate>
                    <DataTemplate x:DataType="vm:DocumentTabViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" Foreground="Black" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding IndexProgress, StringFormat='{}{0:P0}'}"
                                       Foreground="Black" VerticalAlignment="Center"
                                       IsVisible="{Binding IsIndexing}" />
                            <Button Content="×" Padding="4,0" MinWidth="0" Background="Transparent"
                                    Foreground="Black"
                                    Command="{Binding CloseCommand}" />
                        </StackPanel>
                    </DataTemplate>
                </TabStrip.ItemTemplate>
            </TabStrip>
        </Border>

        <!-- ツールバー -->
        <Border DockPanel.Dock="Top" Background="#EEEEEE" BorderBrush="#CCCCCC"
                BorderThickness="0,0,0,1" Padding="6">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="OpenButton" Content="開く…" />
                <TextBlock Text="文字コード:" VerticalAlignment="Center" Foreground="Black" />
                <ComboBox x:Name="EncodingCombo" MinWidth="130"
                          ItemsSource="{Binding EncodingOptions}"
                          SelectedItem="{Binding SelectedEncoding, Mode=TwoWay}" />
                <CheckBox x:Name="LineNumberCheck" Content="行番号" IsChecked="True" Foreground="Black" />
                <Rectangle Width="1" Fill="#CCCCCC" Margin="4,0" />
                <TextBlock Text="ジャンプ:" VerticalAlignment="Center" Foreground="Black" />
                <TextBox x:Name="JumpBox" Width="110" PlaceholderText="行 / %"
                         Text="{Binding JumpText, Mode=TwoWay}" />
                <Button x:Name="JumpButton" Content="移動" />
                <Rectangle Width="1" Fill="#CCCCCC" Margin="4,0" />
                <Button x:Name="BookmarkToggleButton" Content="☆" ToolTip.Tip="先頭行のブックマークをトグル" />
                <Button x:Name="PrevBookmarkButton" Content="◀☆" ToolTip.Tip="前のブックマークへ" />
                <Button x:Name="NextBookmarkButton" Content="☆▶" ToolTip.Tip="次のブックマークへ" />
                <Rectangle Width="1" Fill="#CCCCCC" Margin="4,0" />
                <ToggleButton x:Name="TailToggle" Content="Tail" ToolTip.Tip="末尾追従（追記を検知して自動スクロール）" />
            </StackPanel>
        </Border>

        <!-- 検索バー（§11-①②⑥） -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#CCCCCC"
                BorderThickness="0,0,0,1" Padding="6,4">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="検索:" VerticalAlignment="Center" Foreground="Black" />
                <TextBox x:Name="SearchBox" Width="220" PlaceholderText="文字列 / 正規表現"
                         Text="{Binding SearchText, Mode=TwoWay}" />
                <Button x:Name="SearchButton" Content="検索" />
                <Button x:Name="ClearSearchButton" Content="×" />
                <CheckBox x:Name="RegexCheck" Content="正規表現" Foreground="Black"
                          IsChecked="{Binding SearchIsRegex, Mode=TwoWay}" />
                <CheckBox x:Name="CaseCheck" Content="大小無視" Foreground="Black"
                          IsChecked="{Binding SearchIgnoreCase, Mode=TwoWay}" />
                <Button x:Name="PrevHitButton" Content="◀ 前へ" />
                <Button x:Name="NextHitButton" Content="次へ ▶" />
                <ToggleButton x:Name="FilterToggle" Content="フィルタ表示"
                              ToolTip.Tip="ヒット行だけを表示（§11-⑤）" />
                <TextBlock Text="{Binding SearchInfo}" VerticalAlignment="Center" Foreground="Black" />
            </StackPanel>
        </Border>

        <!-- ステータスバー -->
        <Border DockPanel.Dock="Bottom" Background="#EEEEEE" BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0" Padding="6,3">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <TextBlock Text="{Binding FilePath}" Foreground="Black" />
                    <TextBlock Text="{Binding ModeInfo}" Foreground="Black" />
                    <TextBlock Text="{Binding PositionInfo}" Foreground="Black" />
                    <TextBlock Text="{Binding EncodingInfo}" Foreground="Black" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding IsIndexing}">
                    <TextBlock Text="索引中" VerticalAlignment="Center" Foreground="Black" />
                    <ProgressBar Width="140" Minimum="0" Maximum="1"
                                 Value="{Binding IndexProgress}" />
                    <Button x:Name="CancelButton" Content="キャンセル" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 本文 + ミニマップ + 縦スクロールバー -->
        <Grid ColumnDefinitions="*,Auto,Auto">
            <ctrl:TextView x:Name="TextView" Grid.Column="0" />
            <ctrl:MinimapView x:Name="Minimap" Grid.Column="1" />
            <ScrollBar x:Name="VScroll" Grid.Column="2" Orientation="Vertical"
                       AllowAutoHide="False" Width="16" />
        </Grid>

    </DockPanel>
</UserControl>
